# cp .env.example .env and fill these in.
#
# Read this once. The layout of this file is the product.

MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Your deploy key. Hot, scriptable, reachable by every agent you run.
# Nchedo assumes this key ends up somewhere public. That is not pessimism —
# it is the thing that has already happened to you at least once.
VAULT_OWNER_KEY=

# The canary. It must live in THIS file, next to the key above.
#
# A canary in a different file, or a file you are careful with, is a canary
# that survives the leak that mattered. This one is only useful because it
# goes public in the same commit, the same paste, the same screenshot.
#
# Nothing legitimate ever signs with it. If it moves, you are compromised.
CANARY_KEY=

# Not here. Never here. This is the only key that can save a locked vault,
# and a repo is not where you keep it.
# RECOVERY_KEY=
